<!-- importa o header -->
<%- include('../partials/header') %>

<body>
  <h1 class="logo">StudyFlow</h1>
  <div class="container" id="container">
    <div class="form-container sign-up">
      <form>
        <h1>StudyFlow</h1>

        <h1>Criar Conta</h1>
        <span>Ou crie usando o Seu E-mail e senha</span>
        <input type="text" placeholder="Nome" />
        <input type="email" placeholder="Email" />
        <input type="password" placeholder="Senha" />
        <button>Criar Conta</button>
      </form>
    </div>
    <div class="form-container sign-in">
      <form action="/usuarios/login" method="post">
        <h1>Entrar</h1>
        <span>Ou entre usando E-mail e Senha</span>
        <input
          type="email"
          id="email_login"
          name="email"
          class="form-control"
          placeholder="Email"
          required  
        />
        <input
          type="password"
          id="senha_login"
          name="senha"
          class="form-control"
          placeholder="Senha"
          required
        />
        <link rel="stylesheet" href="style.css" />
        <button>Entrar</button>
      </form>
    </div>
    <div class="toggle-container">
      <div class="toggle">
        <div class="toggle-panel toggle-left">
          <h1>Bem-vindo de volta!</h1>
          <p>Insira seus dados pessoais para usar todos os recursos do site</p>
          <button class="hidden" id="login">Entrar</button>
        </div>
        <div class="toggle-panel toggle-right">
          <h1>Crie sua conta!</h1>
          <p>
            Registre-se com seus dados pessoais para usar todos os recursos do
            site
          </p>
          <button class="hidden" id="register">Criar Conta</button>
        </div>
      </div>
    </div>
  </div>
</body>

<!-- importa o footer -->
<%- include('../partials/footer') %>
