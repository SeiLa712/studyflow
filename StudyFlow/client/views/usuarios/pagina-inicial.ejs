<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StudyFlow</title>

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />

    <link rel="stylesheet" href="/css/barra-lateral.css" />
    <link rel="stylesheet" href="/css/pagina-inicial.css" />
  </head>

  <body>
    <% locals.pagina = "pagina-inicial"; %>
    <%- include('../partials/barra-lateral') %>

    <%
      const listaFallback =
        typeof atividades !== "undefined"
          ? atividades
          : [];

      const listaProximas =
        typeof atividadesProximas !== "undefined"
          ? atividadesProximas
          : listaFallback;

      const listaCalendario =
        typeof atividadesCalendario !== "undefined"
          ? atividadesCalendario
          : listaFallback;

      function formatarDataISO(data) {
        const dataObj = new Date(data);

        const ano = dataObj.getUTCFullYear();
        const mes = String(dataObj.getUTCMonth() + 1).padStart(2, "0");
        const dia = String(dataObj.getUTCDate()).padStart(2, "0");

        return `${ano}-${mes}-${dia}`;
      }

      function formatarDataBR(data) {
        const dataISO = formatarDataISO(data);
        const partes = dataISO.split("-");

        return `${partes[2]}/${partes[1]}/${partes[0]}`;
      }
    %>

    <main class="dashboard">
      <section class="main-content">
        <div class="header">
          <div>
            <h1>Bem-vindo ao StudyFlow</h1>
            <p>Organize seus estudos e aumente sua produtividade.</p>
          </div>

          <button class="btn-add" id="openModal">
            Adicionar Atividade
          </button>
        </div>

        <div class="activities">
          <div
            style="
              display: flex;
              justify-content: space-between;
              align-items: center;
            "
          >
            <h2>Próximas Atividades</h2>
          </div>

          <div id="tasksContainer">
            <% if (!listaProximas || listaProximas.length === 0) { %>
              <div class="task-empty">
                <i class="fa-solid fa-circle-check"></i>
                <p>Nenhuma atividade próxima no momento.</p>
              </div>
            <% } %>

            <% listaProximas.forEach(atividade => { %>
              <%
                const dataAtividadeISO = formatarDataISO(atividade.data_vencimento);
                const dataAtividadeBR = formatarDataBR(atividade.data_vencimento);
              %>

              <div
                class="task-card
                <%= atividade.prioridade === 'alta'
                  ? 'urgent'
                  : atividade.prioridade === 'media'
                  ? 'medium'
                  : 'low' %>"
                data-id="<%= atividade.id %>"
                data-titulo="<%= atividade.nome %>"
                data-descricao="<%= atividade.descricao || 'Sem descrição.' %>"
                data-data="<%= dataAtividadeISO %>"
                data-prioridade="<%= atividade.prioridade %>"
              >
                <div>
                  <h3><%= atividade.nome %></h3>

                  <p>
                    <%= dataAtividadeBR %>
                  </p>

                  <% if (atividade.prioridade) { %>
                    <span class="task-priority">
                      <%= atividade.prioridade === 'alta'
                        ? 'Alta prioridade'
                        : atividade.prioridade === 'media'
                        ? 'Média prioridade'
                        : 'Baixa prioridade' %>
                    </span>
                  <% } %>
                </div>

                <div class="task-actions">
                  <button
                    class="btn-complete"
                    type="button"
                    title="Concluir atividade"
                    data-id="<%= atividade.id %>"
                  >
                    <i class="fa-solid fa-check"></i>
                  </button>
                  
                  <button
                    class="btn-edit"
                    type="button"
                    title="Editar atividade"
                    data-id="<%= atividade.id %>"
                    data-nome="<%= atividade.nome %>"
                    data-descricao="<%= atividade.descricao || '' %>"
                    data-data="<%= dataAtividadeISO %>"
                    data-prioridade="<%= atividade.prioridade %>"
                  >
                    <i class="fa-solid fa-pen"></i>
                  </button>

                  <button
                    class="btn-delete"
                    type="button"
                    title="Excluir atividade"
                  >
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <section class="weekly-calendar">
          <div class="calendar-header">
            <h2>Calendário Semanal</h2>
            <span id="weekRange"></span>
          </div>

          <div class="calendar-grid" id="calendarGrid"></div>
        </section>
      </section>

      <aside class="pomodoro-card">
        <h2>Timer Rápido</h2>

        <div class="timer-circle">25:00</div>

        <button class="play-btn">Iniciar</button>

        <button class="reset-btn">Reiniciar</button>
      </aside>
    </main>

    <!-- MODAL ADICIONAR ATIVIDADE -->
    <div class="modal-overlay" id="modalOverlay">
      <div class="modal">
        <div class="modal-header">
          <h2>Adicionar Nova Atividade</h2>

          <button id="closeModal" type="button">
            ✕
          </button>
        </div>

        <form id="activityForm" action="/tarefas/criar" method="POST">
          <input
            type="hidden"
            name="redirectTo"
            value="/usuarios/pagina-inicial"
          />

          <label>Título</label>
          <input
            type="text"
            id="nome"
            name="nome"
            required
            placeholder="Ex: Estudar Banco de Dados"
          />

          <label>Descrição</label>
          <textarea
            name="descricao"
            placeholder="Descrição da atividade..."
          ></textarea>

          <label>Data</label>
          <input
            type="date"
            name="data_vencimento"
            required
          />

          <label>Urgência</label>
          <select name="prioridade" required>
            <option value="baixa">Baixa</option>
            <option value="media">Média</option>
            <option value="alta">Alta</option>
          </select>

          <div class="modal-buttons">
            <button type="button" class="cancel-btn" id="cancelModal">
              Cancelar
            </button>

            <button type="submit" class="save-btn">
              Adicionar
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- MODAL DETALHES DA ATIVIDADE -->
    <div class="modal-overlay" id="modalDetalhesOverlay">
      <div class="modal">
        <div class="modal-header">
          <h2 id="detalheTitulo">Detalhes da Atividade</h2>

          <button id="closeDetalhesModal" type="button">
            ✕
          </button>
        </div>

        <div class="detalhes-atividade">
          <p>
            <strong>Descrição:</strong>
            <span id="detalheDescricao"></span>
          </p>

          <p>
            <strong>Data:</strong>
            <span id="detalheData"></span>
          </p>

          <p>
            <strong>Prioridade:</strong>
            <span id="detalhePrioridade"></span>
          </p>
        </div>
      </div>
    </div>

    <!-- MODAL EDITAR ATIVIDADE -->
    <div class="modal-overlay" id="modalEditarOverlay">
      <div class="modal">
        <div class="modal-header">
          <h2>Editar Atividade</h2>

          <button id="closeEditModal" type="button">
            ✕
          </button>
        </div>

        <form id="editActivityForm" method="POST">
          <input
            type="hidden"
            name="redirectTo"
            value="/usuarios/pagina-inicial"
          />

          <label>Título</label>
          <input
            type="text"
            id="editNome"
            name="nome"
            required
          />

          <label>Descrição</label>
          <textarea
            id="editDescricao"
            name="descricao"
          ></textarea>

          <label>Data</label>
          <input
            type="date"
            id="editData"
            name="data_vencimento"
            required
          />

          <label>Prioridade</label>
          <select
            id="editPrioridade"
            name="prioridade"
            required
          >
            <option value="baixa">Baixa</option>
            <option value="media">Média</option>
            <option value="alta">Alta</option>
          </select>

          <div class="modal-buttons">
            <button
              type="button"
              class="cancel-btn"
              id="cancelEditModal"
            >
              Cancelar
            </button>

            <button type="submit" class="save-btn">
              Salvar Alterações
            </button>
          </div>
        </form>
      </div>
    </div>

    <script>
      window.atividades = <%- JSON.stringify(listaCalendario || []) %>;
    </script>

    <script src="/js/pagina-inicial.js"></script>
  </body>
</html>