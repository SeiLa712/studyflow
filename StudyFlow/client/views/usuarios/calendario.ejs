<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Calendário - StudyFlow</title>

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />

    <link rel="stylesheet" href="/css/barra-lateral.css" />
    <link rel="stylesheet" href="/css/calendario.css" />
  </head>

  <body>
    <% locals.pagina = "calendario"; %>
    <%- include('../partials/barra-lateral') %>

    <%
      const listaTarefas = tarefas || [];

      const dataAtual = new Date();

      const anoAtual = typeof ano !== "undefined"
        ? Number(ano)
        : dataAtual.getFullYear();

      const mesAtual = typeof mes !== "undefined"
        ? Number(mes)
        : dataAtual.getMonth();

      const nomeMes = new Date(
        anoAtual,
        mesAtual
      ).toLocaleDateString(
        "pt-BR",
        {
          month: "long",
          year: "numeric"
        }
      );

      const primeiroDia = new Date(
        anoAtual,
        mesAtual,
        1
      ).getDay();

      const diasNoMes = new Date(
        anoAtual,
        mesAtual + 1,
        0
      ).getDate();

      const ehMesAtual =
        mesAtual === dataAtual.getMonth() &&
        anoAtual === dataAtual.getFullYear();
      
      function formatarDataISO(data) {
        if (!data) return "";

        if (typeof data === "string" && data.length >= 10) {
          return data.substring(0, 10);
        }

        const dataObj = new Date(data);

        const ano = dataObj.getUTCFullYear();
        const mes = String(dataObj.getUTCMonth() + 1).padStart(2, "0");
        const dia = String(dataObj.getUTCDate()).padStart(2, "0");

        return `${ano}-${mes}-${dia}`;
      }
    %>

    <div class="main-container">
      <main class="calendar-section">
        <header class="calendar-header">
          <div class="title-group">
            <h1>Calendário</h1>

            <p class="subtitle">
              Visualize todas as suas atividades acadêmicas
            </p>
          </div>

          <button
            class="btn-nova-atividade"
            id="openModal"
            type="button"
          >
            Adicionar Atividade
          </button>
        </header>

        <div class="month-navigation">
          <button
            class="arrow-btn"
            id="prevMonth"
            type="button"
            title="Mês anterior"
          >
            <i class="fas fa-chevron-left"></i>
          </button>

          <div class="month-title-box">
          <h2
            id="currentMonth"
            data-mes="<%= mesAtual %>"
            data-ano="<%= anoAtual %>"
            >
            <%= nomeMes %>
          </h2>
          
          <% if (ehMesAtual) { %>
            <span class="current-month-label">
              mês atual
            </span>
          <% } %>
        </div>

          <button
            class="arrow-btn"
            id="nextMonth"
            type="button"
            title="Próximo mês"
          >
            <i class="fas fa-chevron-right"></i>
          </button>
        </div>

        <div class="calendar-grid-container">
          <div class="weekday-header">Dom</div>
          <div class="weekday-header">Seg</div>
          <div class="weekday-header">Ter</div>
          <div class="weekday-header">Qua</div>
          <div class="weekday-header">Qui</div>
          <div class="weekday-header">Sex</div>
          <div class="weekday-header">Sáb</div>

          <% for (let i = 0; i < primeiroDia; i++) { %>
            <div class="calendar-day empty"></div>
          <% } %>

          <% for (let dia = 1; dia <= diasNoMes; dia++) { %>
            <%
              const dataDia = `${anoAtual}-${String(mesAtual + 1).padStart(2, "0")}-${String(dia).padStart(2, "0")}`;
            %>

            <div
              class="calendar-day"
              data-date="<%= dataDia %>"
            >
              <span class="day-number">
                <%= dia %>
              </span>

              <div class="activities-wrapper">
                <% listaTarefas.forEach(tarefa => { %>
                  <%
                    const dataTarefaISO = formatarDataISO(tarefa.data_vencimento);
                    const partesData = dataTarefaISO.split("-");

                    const anoTarefa = Number(partesData[0]);
                    const mesTarefa = Number(partesData[1]) - 1;
                    const diaTarefa = Number(partesData[2]);

                    let classeCor = "tag-estudo";

                    if (tarefa.prioridade === "alta") {
                      classeCor = "tag-prova";
                    } else if (tarefa.prioridade === "media") {
                      classeCor = "tag-trabalho";
                    }

                    const tarefaConcluida =
                      tarefa.concluida === true ||
                      tarefa.concluida === 1;
                  %>

                  <% if (
                    diaTarefa === dia &&
                    mesTarefa === mesAtual &&
                    anoTarefa === anoAtual
                  ) { %>
                    <div
                      class="activity-tag <%= classeCor %> <%= tarefaConcluida ? 'concluida' : '' %>"
                      title="<%= tarefa.nome %>"
                      data-id="<%= tarefa.id %>"
                      data-titulo="<%= tarefa.nome %>"
                      data-descricao="<%= tarefa.descricao || '' %>"
                      data-data="<%= dataTarefaISO %>"
                      data-prioridade="<%= tarefa.prioridade %>"
                      data-concluida="<%= tarefaConcluida ? 'true' : 'false' %>"
                    >
                      <%= tarefaConcluida ? '✓ ' : '' %><%= tarefa.nome %>
                    </div>
                  <% } %>
                <% }) %>
              </div>
            </div>
          <% } %>
        </div>
      </main>
    </div>

    <!-- MODAL ADICIONAR ATIVIDADE -->
    <div
      class="modal-overlay"
      id="modalOverlay"
    >
      <div class="modal">
        <div class="modal-header">
          <h2>
            Adicionar Nova Atividade
          </h2>

          <button
            id="closeModal"
            type="button"
          >
            ✕
          </button>
        </div>

        <form
          action="/tarefas/criar"
          method="POST"
        >
          <input
            type="hidden"
            name="redirectTo"
            value="/usuarios/calendario?mes=<%= mesAtual %>&ano=<%= anoAtual %>"
          />

          <label>Título</label>

          <input
            type="text"
            name="nome"
            required
          />

          <label>Descrição</label>

          <textarea
            name="descricao"
          ></textarea>

          <label>Data</label>

          <input
            type="date"
            id="data_vencimento"
            name="data_vencimento"
            required
          />

          <label>Prioridade</label>

          <select name="prioridade" required>
            <option value="baixa">
              Baixa
            </option>

            <option value="media">
              Média
            </option>

            <option value="alta">
              Alta
            </option>
          </select>

          <div class="modal-buttons">
            <button
              type="button"
              class="cancel-btn"
              id="cancelModal"
            >
              Cancelar
            </button>

            <button
              type="submit"
              class="save-btn"
            >
              Adicionar
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- MODAL EDITAR ATIVIDADE -->
    <div
      class="modal-overlay"
      id="modalEditarOverlay"
    >
      <div class="modal">
        <div class="modal-header">
          <h2>
            Editar Atividade
          </h2>

          <button
            id="closeEditModal"
            type="button"
          >
            ✕
          </button>
        </div>

        <form
          id="editActivityForm"
          method="POST"
        >
          <input
            type="hidden"
            name="redirectTo"
            value="/usuarios/calendario?mes=<%= mesAtual %>&ano=<%= anoAtual %>"
          />

          <label>Título</label>

          <input
            type="text"
            id="editNome"
            name="nome"
            required
          />

          <label>Descrição</label>

          <textarea
            id="editDescricao"
            name="descricao"
          ></textarea>

          <label>Data</label>

          <input
            type="date"
            id="editData"
            name="data_vencimento"
            required
          />

          <label>Prioridade</label>

          <select
            id="editPrioridade"
            name="prioridade"
            required
          >
            <option value="baixa">Baixa</option>
            <option value="media">Média</option>
            <option value="alta">Alta</option>
          </select>

          <div class="modal-buttons">
            <button
              type="button"
              class="complete-btn"
              id="btnConcluirEdit"
            >
              Marcar como concluída
            </button>

            <button
              type="button"
              class="cancel-btn"
              id="cancelEditModal"
            >
              Cancelar
            </button>

            <button
              type="submit"
              class="save-btn"
            >
              Salvar Alterações
            </button>
          </div>
        </form>
      </div>
    </div>

    <script src="/js/calendario.js"></script>
  </body>
</html>