<%- include('../partials/header') %>

<div class="main-container">
    <!-- Inclui a barra lateral oficial do projeto -->
    <%- include('../partials/barra-lateral') %>

    <link rel="stylesheet" href="/StudyFlow/client/public/css/calendario.css">
    <!-- Conteúdo Principal do Calendário -->
    <main class="calendar-section">
        <header class="calendar-header">
            <div class="title-group">
                <h1>Calendário</h1>
                <p class="subtitle">Visualize todas as suas atividades acadêmicas</p>
            </div>
            <button class="btn-nova-atividade">+ Nova Atividade</button>
        </header>

        <!-- Navegação do Mês -->
        <div class="month-navigation">
            <h2 id="current-month">Abril 2026</h2>
            <div class="nav-arrows">
                <button class="arrow-btn">&lt;</button>
                <button class="arrow-btn">&gt;</button>
            </div>
        </div>

        <!-- Grade dos dias -->
        <div class="calendar-grid-container">
            <div class="weekday-header">Dom</div>
            <div class="weekday-header">Seg</div>
            <div class="weekday-header">Ter</div>
            <div class="weekday-header">Qua</div>
            <div class="weekday-header">Qui</div>
            <div class="weekday-header">Sex</div>
            <div class="weekday-header">Sáb</div>

            <!-- Espaços vazios: Abril de 2026 começa na Quarta-feira -->
            <div class="calendar-day empty"></div>
            <div class="calendar-day empty"></div>
            <div class="calendar-day empty"></div>

            <!-- Geração automática dos 30 dias do mês -->
            <% for(let dia = 1; dia <= 30; dia++) { %>
                
                <!-- O dia 12 fica destacado visualmente para seguir o seu mockup original -->
                <div class="calendar-day <%= dia === 12 ? 'selected-day' : '' %>">
                    <span class="day-number"><%= dia %></span>
                    
                    <div class="activities-wrapper">
                        <!-- Varre as tarefas que vieram do Banco de Dados através da rota -->
                        <% if (typeof tarefas !== 'undefined' && tarefas.length > 0) { %>
                            <% tarefas.forEach(tarefa => { %>
                                <% 
                                   // Formata a data vinda do MySQL para pegar o dia do mês correto
                                   const dataTarefa = new Date(tarefa.data);
                                   const diaDaTarefa = dataTarefa.getUTCDate();
                                   
                                   // Filtra a categoria para aplicar a cor correspondente
                                   const categoria = tarefa.categoria ? tarefa.categoria.toLowerCase() : '';
                                %>

                                <% if (diaDaTarefa === dia) { %>
                                    <!-- Define a cor da tag de acordo com a categoria no banco -->
                                    <% 
                                        let classeCor = 'tag-estudo'; // Azul padrão
                                        if (categoria.includes('prova')) {
                                            classeCor = 'tag-prova'; // Vermelho
                                        } else if (categoria.includes('trabalho') || categoria.includes('entrega')) {
                                            classeCor = 'tag-trabalho'; // Rosa
                                        }
                                    %>
                                    <div class="activity-tag <%= classeCor %>" title="<%= tarefa.titulo %>">
                                        <%= tarefa.titulo %>
                                    </div>
                                <% } %>
                            <% }) %>
                        <% } %>
                    </div>
                </div>
            <% } %>
        </div>

        <!-- Legenda inferior -->
        <footer class="legend-container">
            <div class="legend-item"><span class="bullet bullet-prova"></span> Prova</div>
            <div class="legend-item"><span class="bullet bullet-trabalho"></span> Trabalho</div>
            <div class="legend-item"><span class="bullet bullet-estudo"></span> Estudo</div>
        </footer>
    </main>
</div>

<%- include('../partials/footer') %>