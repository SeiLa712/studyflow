<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Grupos de Estudo - StudyFlow</title>

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />

    <link rel="stylesheet" href="/css/grupos.css" />
  </head>

  <body>
    <%- include('../partials/barra-lateral') %>

    <main class="grupos-container">
      <div class="header">
        <div>
          <h1>Grupos de Estudo</h1>
          <p>Colabore com colegas em trabalhos e estudos</p>
        </div>

        <button class="btn-add" id="openModal" type="button">
          Novo Grupo
        </button>
      </div>

      <!-- GRUPOS CRIADOS -->
      <section class="grupos-section">
        <div class="section-title">
          <h2>Grupos que eu criei</h2>
          <p>Grupos criados por você</p>
        </div>

        <div class="grupos-grid">
          <% if (!gruposCriados || gruposCriados.length === 0) { %>
            <div class="empty-state">
              <i class="fa-solid fa-users"></i>
              <p>Você ainda não criou nenhum grupo.</p>
            </div>
          <% } %>

          <% gruposCriados.forEach(grupo => { %>
            <div
              class="grupo-card"
              data-id="<%= grupo.id %>"
              data-nome="<%= grupo.nome %>"
            >
              <div class="grupo-header">
                <h3><%= grupo.nome %></h3>

                <button
                  class="btn-delete-grupo"
                  data-id="<%= grupo.id %>"
                  title="Excluir grupo"
                  type="button"
                >
                  <i class="fa-solid fa-trash"></i>
                </button>
              </div>

              <% if (grupo.descricao) { %>
                <p class="disciplina"><%= grupo.descricao %></p>
              <% } else { %>
                <p class="disciplina"><%= grupo.disciplina %></p>
              <% } %>

              <div class="grupo-info">
                <div class="membros">
                  <i class="fa-solid fa-users"></i>
                  <span><%= grupo.total_membros || 0 %> membros</span>

                  <% if (grupo.membros_preview) { %>
                    <span class="membros-list">
                      (<%= grupo.membros_preview %>
                      <% if (grupo.membros_extras > 0) { %>
                        +<%= grupo.membros_extras %>
                      <% } %>)
                    </span>
                  <% } %>
                </div>
              </div>

              <button
                class="btn-add-membro"
                data-id="<%= grupo.id %>"
                type="button"
              >
                Adicionar Membro
              </button>
            </div>
          <% }) %>
        </div>
      </section>

      <!-- GRUPOS QUE PARTICIPO -->
      <section class="grupos-section">
        <div class="section-title">
          <h2>Grupos que participo</h2>
          <p>Grupos onde você foi adicionado como membro</p>
        </div>

        <div class="grupos-grid">
          <% if (!gruposParticipando || gruposParticipando.length === 0) { %>
            <div class="empty-state">
              <i class="fa-solid fa-user-group"></i>
              <p>Você ainda não foi adicionado em nenhum grupo.</p>
            </div>
          <% } %>

          <% gruposParticipando.forEach(grupo => { %>
            <div
              class="grupo-card grupo-participando"
              data-id="<%= grupo.id %>"
              data-nome="<%= grupo.nome %>"
            >
              <div class="grupo-header">
                <h3><%= grupo.nome %></h3>
                <span class="badge-participando">Participando</span>
              </div>

              <% if (grupo.descricao) { %>
                <p class="disciplina"><%= grupo.descricao %></p>
              <% } else { %>
                <p class="disciplina"><%= grupo.disciplina %></p>
              <% } %>

              <div class="grupo-info">
                <div class="membros">
                  <i class="fa-solid fa-users"></i>
                  <span><%= grupo.total_membros || 0 %> membros</span>

                  <% if (grupo.membros_preview) { %>
                    <span class="membros-list">
                      (<%= grupo.membros_preview %>
                      <% if (grupo.membros_extras > 0) { %>
                        +<%= grupo.membros_extras %>
                      <% } %>)
                    </span>
                  <% } %>
                </div>
              </div>

              <button
                class="btn-add-membro"
                data-id="<%= grupo.id %>"
                type="button"
              >
                Adicionar Membro
              </button>
            </div>
          <% }) %>
        </div>
      </section>
    </main>

    <!-- MODAL CRIAR GRUPO -->
    <div class="modal-overlay" id="modalOverlay">
      <div class="modal">
        <div class="modal-header">
          <h2>Criar Novo Grupo</h2>
          <button id="closeModal" type="button">✕</button>
        </div>

        <form id="grupoForm" action="/usuarios/grupos/criar" method="POST">
          <label>Nome do Grupo</label>
          <input
            type="text"
            id="nome"
            name="nome"
            required
            placeholder="Ex: Grupo TCC"
          />

          <label>Matéria</label>
          <input
            type="text"
            id="disciplina"
            name="disciplina"
            required
            placeholder="Ex: Banco de Dados"
          />

          <label>Descrição (opcional)</label>
          <textarea
            name="descricao"
            placeholder="Descreva o objetivo do grupo..."
          ></textarea>

          <div class="modal-buttons">
            <button type="button" class="cancel-btn" id="cancelModal">
              Cancelar
            </button>

            <button type="submit" class="save-btn">
              Criar Grupo
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- MODAL ADICIONAR MEMBRO -->
    <div class="modal-overlay" id="modalMembroOverlay">
      <div class="modal">
        <div class="modal-header">
          <h2>Adicionar Membro</h2>
          <button id="closeModalMembro" type="button">✕</button>
        </div>

        <form id="membroForm">
          <input type="hidden" id="grupoId" name="grupoId" />

          <label>Email do Usuário</label>
          <input
            type="email"
            id="email_usuario"
            name="email_usuario"
            required
            placeholder="email@exemplo.com"
          />

          <div class="modal-buttons">
            <button type="button" class="cancel-btn" id="cancelModalMembro">
              Cancelar
            </button>

            <button type="submit" class="save-btn">
              Adicionar
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- MODAL ARQUIVOS DO GRUPO -->
    <div class="modal-overlay" id="modalArquivosOverlay">
      <div class="modal modal-arquivos">
        <div class="modal-header">
          <h2 id="tituloModalArquivos">Arquivos do Grupo</h2>
          <button id="closeModalArquivos" type="button">✕</button>
        </div>

        <form id="arquivoForm" enctype="multipart/form-data">
          <input type="hidden" id="arquivoGrupoId" name="grupoId" />

          <label>Enviar novo arquivo</label>

          <div class="upload-arquivo-box">
            <input
              type="file"
              id="arquivoGrupo"
              name="arquivo"
              required
            />

            <button type="submit" class="save-btn">
              Enviar
            </button>
          </div>
        </form>

        <div class="arquivos-area">
          <h3>Arquivos disponíveis</h3>

          <div id="listaArquivosGrupo" class="arquivos-list">
            <p>Carregando arquivos...</p>
          </div>
        </div>
      </div>
    </div>

    <script>
      window.grupos = <%- JSON.stringify([
        ...(gruposCriados || []),
        ...(gruposParticipando || [])
      ]) %>;
    </script>

    <script src="/js/grupos.js"></script>
  </body>
</html>