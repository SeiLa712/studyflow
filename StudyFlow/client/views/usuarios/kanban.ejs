<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StudyFlow - Kanban</title>

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />

    <link rel="stylesheet" href="/css/barra-lateral.css" />
    <link rel="stylesheet" href="/css/kanban.css" />
  </head>

  <body>
    <% locals.pagina = "kanban"; %>
    <%- include('../partials/barra-lateral') %>

    <%
      const listaColunas = typeof colunas !== "undefined" ? colunas : [];
      const listaCards = typeof cards !== "undefined" ? cards : [];
      const dadosKanban = typeof kanban !== "undefined" ? kanban : { id: null, nome: "Quadro Kanban" };
    %>

    <main class="kanban-board-page">
      <header class="kanban-header">
        <div>
          <h1><%= dadosKanban.nome || "Quadro Kanban" %></h1>
          <p>Organize suas atividades acadêmicas em colunas de progresso.</p>
        </div>

        <button class="btn-primary" type="button" onclick="abrirModalColuna()">
          Nova Coluna
        </button>
      </header>

      <section class="kanban-board">
        <% if (!listaColunas || listaColunas.length === 0) { %>
          <div class="empty-column">
            Nenhuma coluna encontrada. Clique em "Nova Coluna" para começar.
          </div>
        <% } %>

        <% listaColunas.forEach(coluna => { %>
          <%
            const cardsDaColuna = listaCards.filter(card => card.id_coluna == coluna.id);
          %>

          <div class="kanban-column" data-column-id="<%= coluna.id %>">
            <div class="column-header">
              <h2><%= coluna.nome %></h2>

              <span class="column-count">
                <%= cardsDaColuna.length %>
              </span>
            </div>

            <div class="cards-container" data-column-id="<%= coluna.id %>">
              <% if (cardsDaColuna.length === 0) { %>
                <div class="empty-column">
                  Arraste cards para cá ou adicione um novo.
                </div>
              <% } %>

              <% cardsDaColuna.forEach(card => { %>
                <article
                  class="kanban-card"
                  draggable="true"
                  data-card-id="<%= card.id %>"
                >
                  <div class="card-header">
                    <h3><%= card.titulo %></h3>
                  </div>

                  <% if (card.descricao) { %>
                    <p><%= card.descricao %></p>
                  <% } else { %>
                    <p>Sem descrição.</p>
                  <% } %>
                </article>
              <% }) %>
            </div>

            <button
              class="btn-add-card"
              type="button"
              onclick="abrirModalCard('<%= coluna.id %>')"
            >
              Adicionar card
            </button>
          </div>
        <% }) %>
      </section>
    </main>

    <!-- MODAL CRIAR COLUNA -->
    <div class="modal-overlay" id="modalColuna">
      <div class="modal">
        <div class="modal-header">
          <h2>Nova Coluna</h2>

          <button type="button" onclick="fecharModalColuna()">
            ✕
          </button>
        </div>

        <form action="/kanban/colunas" method="POST">
          <input
            type="hidden"
            name="idKanban"
            value="<%= dadosKanban.id %>"
          />

          <label>Nome da coluna</label>
          <input
            type="text"
            name="nome"
            placeholder="Ex: A Fazer"
            required
          />

          <div class="modal-buttons">
            <button
              type="button"
              class="cancel-btn"
              onclick="fecharModalColuna()"
            >
              Cancelar
            </button>

            <button type="submit" class="save-btn">
              Criar Coluna
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- MODAL CRIAR CARD -->
    <div class="modal-overlay" id="modalCard">
      <div class="modal">
        <div class="modal-header">
          <h2>Novo Card</h2>

          <button type="button" onclick="fecharModalCard()">
            ✕
          </button>
        </div>

        <form action="/kanban/cards" method="POST">
          <input
            type="hidden"
            name="id_coluna"
            id="inputIdColuna"
          />

          <label>Título</label>
          <input
            type="text"
            name="titulo"
            placeholder="Ex: Estudar Banco de Dados"
            required
          />

          <label>Descrição</label>
          <textarea
            name="descricao"
            placeholder="Digite uma descrição para o card..."
          ></textarea>

          <div class="modal-buttons">
            <button
              type="button"
              class="cancel-btn"
              onclick="fecharModalCard()"
            >
              Cancelar
            </button>

            <button type="submit" class="save-btn">
              Adicionar Card
            </button>
          </div>
        </form>
      </div>
    </div>

    <script>
      // =========================
      // MODAIS
      // =========================

      function abrirModalColuna() {
        const modal = document.getElementById("modalColuna");
        modal.classList.add("show");
      }

      function fecharModalColuna() {
        const modal = document.getElementById("modalColuna");
        modal.classList.remove("show");
      }

      function abrirModalCard(idColuna) {
        const inputIdColuna = document.getElementById("inputIdColuna");
        const modal = document.getElementById("modalCard");

        inputIdColuna.value = idColuna;
        modal.classList.add("show");
      }

      function fecharModalCard() {
        const modal = document.getElementById("modalCard");
        modal.classList.remove("show");
      }

      document.querySelectorAll(".modal-overlay").forEach((modal) => {
        modal.addEventListener("click", (e) => {
          if (e.target === modal) {
            modal.classList.remove("show");
          }
        });
      });

      // =========================
      // DRAG AND DROP
      // =========================

      let draggedCard = null;

      function atualizarContadores() {
        document.querySelectorAll(".kanban-column").forEach((coluna) => {
          const contador = coluna.querySelector(".column-count");
          const totalCards = coluna.querySelectorAll(".kanban-card").length;

          if (contador) {
            contador.textContent = totalCards;
          }
        });
      }

      function removerEmptyState(container) {
        const empty = container.querySelector(".empty-column");

        if (empty) {
          empty.remove();
        }
      }

      function adicionarEmptyStateSeNecessario(container) {
        const temCard = container.querySelector(".kanban-card");

        if (!temCard) {
          const empty = document.createElement("div");
          empty.classList.add("empty-column");
          empty.textContent = "Arraste cards para cá ou adicione um novo.";

          container.appendChild(empty);
        }
      }

      document.querySelectorAll(".kanban-card").forEach((card) => {
        card.addEventListener("dragstart", () => {
          draggedCard = card;
          card.classList.add("dragging");
        });

        card.addEventListener("dragend", () => {
          card.classList.remove("dragging");
          draggedCard = null;

          document.querySelectorAll(".cards-container").forEach((container) => {
            container.classList.remove("drag-over");
          });
        });
      });

      document.querySelectorAll(".cards-container").forEach((container) => {
        container.addEventListener("dragover", (e) => {
          e.preventDefault();
          container.classList.add("drag-over");
        });

        container.addEventListener("dragleave", () => {
          container.classList.remove("drag-over");
        });

        container.addEventListener("drop", async (e) => {
          e.preventDefault();

          if (!draggedCard) return;

          const containerAnterior = draggedCard.parentElement;

          removerEmptyState(container);

          container.appendChild(draggedCard);
          container.classList.remove("drag-over");

          adicionarEmptyStateSeNecessario(containerAnterior);
          atualizarContadores();

          const idCard = draggedCard.dataset.cardId;
          const idColuna = container.dataset.columnId;

          try {
            await fetch("/kanban/cards/mover", {
              method: "PUT",
              headers: {
                "Content-Type": "application/json"
              },
              body: JSON.stringify({
                idCard,
                idColuna
              })
            });
          } catch (erro) {
            console.error("Erro ao mover card:", erro);
            alert("Erro ao mover card.");
          }
        });
      });
    </script>
  </body>
</html>