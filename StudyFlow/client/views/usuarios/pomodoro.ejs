<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pomodoro</title>
    <link rel="stylesheet" href="../css/pomodoro.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
  </head>

<body>
        <!-- SIDEBAR -->
        <%- include('../partials/barra-lateral') %>
        <!-- CONTEÚDO -->
    <div class="container"></div>
        <main class="content">

            <!-- CABEÇALHO -->

            <div class="header">

                <div>

                    <h1>
                        Técnica Pomodoro
                    </h1>

                    <p>
                        Mantenha o foco com intervalos programados
                    </p>

                </div>

            </div>

            <!-- GRID -->

            <div class="grid">

                <!-- CARD TIMER -->

                <section class="timer-card">

                    <div class="timer-tabs">

                        <button class="tab active">
                            Foco
                        </button>

                        <button class="tab">
                            Pausa
                        </button>

                    </div>

                    <div class="timer-circle">

                        <h1 id="timerDisplay">
                            25:00
                        </h1>

                    </div>

                    <p class="timer-text">
                        Sessão de foco
                    </p>

                    <div class="timer-buttons">

                        <button
                            id="btnPlay"
                            onclick="iniciarTimer()"
                        >
                            ▶
                        </button>

                        <button
                            id="btnPause"
                            onclick="pausarTimer()"
                        >
                            ⏸
                        </button>

                        <button
                            id="btnReset"
                            onclick="resetarTimer()"
                        >
                            ↻
                        </button>

                    </div>

                </section>

                <!-- SESSÕES -->

                <aside class="sessions-card">

                    <div class="sessions-header">

                        <h2>
                            Sessões de Estudo
                        </h2>

                        <button
                            class="novaSessao"
                            onclick="abrirFormulario()"
                        >
                            + Nova Sessão
                        </button>

                    </div>

                    <!-- FORMULÁRIO -->

                    <div
                        id="formularioSessao"
                        class="formulario"
                    >

                        <input
                            type="text"
                            id="nomeSessao"
                            placeholder="Nome da sessão"
                        >

                        <input
                            type="number"
                            id="tempoFoco"
                            placeholder="Tempo de foco (min)"
                        >

                        <input
                            type="number"
                            id="tempoPausa"
                            placeholder="Tempo de pausa (min)"
                        >

                        <div class="form-buttons">

                            <button onclick="salvarSessao()">
                                Salvar
                            </button>

                            <button onclick="fecharFormulario()">
                                Cancelar
                            </button>

                        </div>

                    </div>

                    <!-- LISTA -->

                    <div id="listaSessoes">

                    </div>

                </aside>

            </div>

        </main>

    </div>
    <script src="pomodoro.js"></script>

</body>

</html>