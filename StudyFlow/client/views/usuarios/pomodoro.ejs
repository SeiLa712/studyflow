<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pomodoro - StudyFlow</title>

    <link rel="stylesheet" href="/css/pomodoro.css">

    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>

<body>

    <%- include('../partials/barra-lateral') %>

    <main class="pomodoro-content">

        <div class="header">
            <div>
                <h1>Técnica Pomodoro</h1>
                <p>Mantenha o foco com intervalos programados</p>
            </div>
        </div>

        <div class="grid">

            <!-- TIMER -->
            <section class="timer-card">

                <!-- TABS -->
                <div class="timer-tabs">

                    <button class="tab active">
                        Foco
                    </button>

                    <button class="tab">
                        Pausa
                    </button>

                </div>

                <!-- TIMER CÍRCULO (SVG) -->
                <div class="timer-circle">

                    <svg class="progress-ring" width="280" height="280" viewBox="0 0 280 280">
                        <circle class="ring-bg" cx="140" cy="140" r="120"></circle>
                        <circle class="ring-fill" cx="140" cy="140" r="120"></circle>
                    </svg>

                    <h1 id="timerDisplay">25:00</h1>

                </div>

                <!-- TEXTO -->
                <p class="timer-text" id="timerText">
                    Sessão de foco
                </p>

                <!-- BOTÕES -->
                <div class="timer-buttons">

                    <button id="btnToggle" onclick="toggleTimer()">▶</button>
                    <button id="btnReset" onclick="resetarTimer()">↻</button>

                </div>

            </section>

            <!-- SESSÕES -->
            <aside class="sessions-card">

                <div class="sessions-header">
                    <h2>Minhas sessões</h2>

                    <button class="novaSessao" onclick="abrirFormulario()">
                        Adicionar nova sessão
                    </button>
                </div>

                <!-- FORMULÁRIO -->
                <div id="formularioSessao" class="formulario">

                    <form action="/usuarios/pomodoro/cadastrar" method="POST">

                        <input type="text" name="nome" placeholder="Nome da sessão" required>

                        <input type="text" name="descricao" placeholder="Descrição">

                        <input type="number" name="foco_min" placeholder="Tempo de foco (min)" required>

                        <input type="number" name="pausa_min" placeholder="Tempo de pausa (min)" required>

                        <input type="number" name="ciclos" placeholder="Quantidade de ciclos" value="4">

                        <div class="form-buttons">

                            <button type="submit">Salvar</button>

                            <button type="button" onclick="fecharFormulario()">
                                Cancelar
                            </button>

                        </div>

                    </form>

                </div>

                <!-- LISTA DE SESSÕES -->
                <div id="listaSessoes">

                    <% if (pomodoros.length === 0) { %>
                        <p>Nenhuma sessão cadastrada.</p>
                    <% } %>

                    <% pomodoros.forEach(pomodoro => { %>

                        <div class="sessao-card"
                            onclick="usarSessao(
                                <%= pomodoro.foco_min %>,
                                <%= pomodoro.pausa_min %>,
                                '<%= pomodoro.nome %>'
                            )">

                            <div class="sessao-topo">

                                <div>
                                    <h3><%= pomodoro.nome %></h3>
                                </div>

                                <div class="acoes-topo">

                                    <a href="/usuarios/pomodoro/excluir/<%= pomodoro.id %>"
                                        class="btn-excluir"
                                        title="Excluir">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>

                                </div>

                            </div>

                            <div class="sessao-info">

                                <span><i class="fa-solid fa-stopwatch"></i> Foco: <%= pomodoro.foco_min %> min</span>
                                <span><i class="fa-solid fa-coffee"></i> Pausa: <%= pomodoro.pausa_min %> min</span>
                                <span><i class="fa-solid fa-sync"></i> Ciclos: <%= pomodoro.ciclos %></span>

                            </div>

                        </div>

                    <% }) %>

                </div>

            </aside>

        </div>

    </main>

    <script src="/js/pomodoro.js"></script>

</body>

</html>